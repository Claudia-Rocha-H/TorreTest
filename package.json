{
  "name": "torre-test",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "test": "npm run test:frontend",
    "test:frontend": "cd frontend && npm test",
    "test:backend": "cd backend && ./mvnw test",
    "test:all": "npm run test:frontend && npm run test:backend",
    "coverage": "npm run coverage:frontend",
    "coverage:frontend": "cd frontend && npm test -- --coverage",
    "coverage:backend": "cd backend && ./mvnw test"
  },
  "devDependencies": {}
}
